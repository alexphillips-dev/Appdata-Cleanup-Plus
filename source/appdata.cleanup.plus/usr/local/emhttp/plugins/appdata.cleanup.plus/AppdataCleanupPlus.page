<?php
require_once("/usr/local/emhttp/plugins/appdata.cleanup.plus/include/helpers.php");

$cssVersion = @filemtime("/usr/local/emhttp/plugins/appdata.cleanup.plus/styles/appdata.cleanup.plus.css");
$scriptVersions = array_filter(array(
  @filemtime("/usr/local/emhttp/plugins/appdata.cleanup.plus/scripts/appdata.cleanup.plus.shared.js"),
  @filemtime("/usr/local/emhttp/plugins/appdata.cleanup.plus/scripts/appdata.cleanup.plus.panels.js"),
  @filemtime("/usr/local/emhttp/plugins/appdata.cleanup.plus/scripts/appdata.cleanup.plus.js")
));
$jsVersion = ! empty($scriptVersions) ? max($scriptVersions) : false;
$hostThemeName = strtolower(trim((string)($display['theme'] ?? "")));
$hostThemeClass = "";
$csrfToken = getAppdataCleanupPlusCsrfToken();
$pluginVersion = "";
$manifestPaths = array(
  "/boot/config/plugins/appdata.cleanup.plus.plg",
  appdataCleanupPlusConfigDir() . "/appdata.cleanup.plus.plg"
);

foreach ( $manifestPaths as $manifestPath ) {
  if ( ! is_file($manifestPath) ) {
    continue;
  }

  $manifestContents = @file_get_contents($manifestPath);
  if ( is_string($manifestContents) && preg_match('/<!ENTITY version "([^"]+)">/', $manifestContents, $versionMatches) ) {
    $pluginVersion = (string)$versionMatches[1];
    break;
  }
}

if ( $hostThemeName === "grey" ) {
  $hostThemeName = "gray";
}

if ( strpos($hostThemeName, "white") !== false || strpos($hostThemeName, "light") !== false ) {
  $hostThemeClass = "light";
} elseif ( strpos($hostThemeName, "black") !== false ) {
  $hostThemeClass = "dark";
}

if ( ! $cssVersion ) {
  $cssVersion = time();
}

if ( ! $jsVersion ) {
  $jsVersion = time();
}

