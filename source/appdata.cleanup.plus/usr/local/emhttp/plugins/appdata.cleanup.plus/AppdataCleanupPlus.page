<script>
window.AppdataCleanupPlusHostThemeName = <?php echo json_encode($hostThemeName, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE); ?>;
(function applyAppdataCleanupPlusHostTheme(rawThemeName) {
  const safeThemeName = String(rawThemeName || '').trim().toLowerCase();
  if (!safeThemeName) {
    return;
  }
  const applyAttrs = () => {
    try {
      document.documentElement?.setAttribute('data-acp-host-theme', safeThemeName);
      document.body?.setAttribute('data-acp-host-theme', safeThemeName);
    } catch (_error) {}
  };
  applyAttrs();
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', applyAttrs, { once: true });
  }
})(window.AppdataCleanupPlusHostThemeName);
</script>
